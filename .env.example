# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# Track 3 note: we supply our OWN keys — the FIREWORKS_*/ALLOWED_MODELS
# harness injection is a Track 1 mechanic and does NOT apply here.

# Which backend serves the Gemma attacker + judge: "fireworks" or "mi300x"
INFERENCE_BACKEND=fireworks

# Gemma model id for the attacker + judge.
#   - fireworks: Gemma is usually deployment-only; use your deployment path.
#   - mi300x:    use the HF id served with vLLM, e.g. google/gemma-3-12b-it.
MODEL_ID=accounts/your-account/deployments/your-gemma-deployment-id

# Fireworks / managed OpenAI-compatible endpoint — used when INFERENCE_BACKEND=fireworks.
# This is a live-demo convenience path, not the committed AMD proof path.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Self-hosted vLLM on MI300X — used when INFERENCE_BACKEND=mi300x
# (OpenAI-compatible endpoint; in the AMD notebook it's http://localhost:8000/v1)
# API key can stay blank — vLLM ignores it (the app sends a placeholder).
MI300X_BASE_URL=
MI300X_API_KEY=

# The system-under-test. On Fireworks these are optional: the app defaults to the
# same Fireworks base URL/key and a serverless target, so live demo setup only needs
# MODEL_ID + FIREWORKS_API_KEY. Override these if you want a different target.
TARGET_ENDPOINT=
TARGET_MODEL_ID=accounts/fireworks/models/gpt-oss-120b
TARGET_API_KEY=

# ---- Cost meter (PRD F8) ----
# USD per 1,000 tokens for the Gemma attacker+judge. Leave at 0 to show an honest
# $0.00 until you fill in measured/published prices. PRICE_SOURCE is displayed in the
# UI next to any figure so a comparison always carries its citation.
PRICE_PER_1K_PROMPT_TOKENS=0
PRICE_PER_1K_COMPLETION_TOKENS=0
PRICE_SOURCE=

# ---- Runtime knobs (safe defaults; override only if needed) ----
# asyncio fan-out cap and per-call timeout. Timeout stays under the 30s/request rule.
MAX_CONCURRENCY=8
REQUEST_TIMEOUT_S=25
