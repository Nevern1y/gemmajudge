# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# Track 3 note: we supply our OWN keys — the FIREWORKS_*/ALLOWED_MODELS
# harness injection is a Track 1 mechanic and does NOT apply here.

# Which backend serves the Attacker + Judge Gemma: "fireworks" or "mi300x"
INFERENCE_BACKEND=fireworks

# The Gemma model id for Attacker + Judge (confirm exact id from Fireworks after launch day)
MODEL_ID=

# Fireworks (AMD-hosted) — used when INFERENCE_BACKEND=fireworks
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Self-hosted vLLM on MI300X — used when INFERENCE_BACKEND=mi300x
# (OpenAI-compatible endpoint, e.g. http://<host>:8000/v1)
MI300X_BASE_URL=
MI300X_API_KEY=

# The system-under-test (deliberately weak model for the demo).
# OpenAI-compatible endpoint + model id.
TARGET_ENDPOINT=
TARGET_MODEL_ID=
TARGET_API_KEY=
