# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# Track 3 note: we supply our OWN keys — the FIREWORKS_*/ALLOWED_MODELS
# harness injection is a Track 1 mechanic and does NOT apply here.

# Which backend serves the Attacker + Judge Gemma: "fireworks" or "mi300x"
INFERENCE_BACKEND=fireworks

# The Gemma model id for Attacker + Judge (strong model -> sharp attacks + reliable judge).
#   - fireworks: confirmed available -> accounts/fireworks/models/gemma-4-31b-it
#                (alts: gemma-4-26b-a4b-it, gemma-3-27b-it, gemma2-9b-it)
#   - mi300x:    the HF id you served with vLLM, e.g. google/gemma-3-12b-it
#                (see docs/amd_proof/ — serve it on the AMD MI300X notebook first)
MODEL_ID=accounts/fireworks/models/gemma-4-31b-it

# Fireworks (AMD-hosted) — used when INFERENCE_BACKEND=fireworks
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Self-hosted vLLM on MI300X — used when INFERENCE_BACKEND=mi300x
# (OpenAI-compatible endpoint; in the AMD notebook it's http://localhost:8000/v1)
# API key can stay blank — vLLM ignores it (the app sends a placeholder).
MI300X_BASE_URL=
MI300X_API_KEY=

# The system-under-test (deliberately weak model for the demo -> dramatic failures).
# On Fireworks, endpoint = the same base URL, key = the same Fireworks key.
#   weak target: accounts/fireworks/models/gemma-3-4b-it  (or gemma-3-1b-it for weaker)
TARGET_ENDPOINT=https://api.fireworks.ai/inference/v1
TARGET_MODEL_ID=accounts/fireworks/models/gemma-3-4b-it
TARGET_API_KEY=

# ---- Cost meter (PRD F8) ----
# USD per 1,000 tokens for the Attacker+Judge Gemma. Leave at 0 to show an honest
# $0.00 until you fill in measured/published prices. PRICE_SOURCE is displayed in the
# UI next to any figure so a comparison always carries its citation.
PRICE_PER_1K_PROMPT_TOKENS=0
PRICE_PER_1K_COMPLETION_TOKENS=0
PRICE_SOURCE=

# ---- Runtime knobs (safe defaults; override only if needed) ----
# asyncio fan-out cap and per-call timeout. Timeout stays under the 30s/request rule.
MAX_CONCURRENCY=8
REQUEST_TIMEOUT_S=25
